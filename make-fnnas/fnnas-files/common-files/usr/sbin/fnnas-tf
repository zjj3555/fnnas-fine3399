#!/bin/bash
#===========================================================================
#
# This file is licensed under the terms of the GNU General Public
# License version 2. This program is licensed "as is" without any
# warranty of any kind, whether express or implied.
#
# This file is a part of the FnNAS project
# https://github.com/ophub/fnnas
#
# Function: Partition expansion tool
# Copyright (C) 2021- https://github.com/unifreq/openwrt_packit
# Copyright (C) 2021- https://github.com/ophub/fnnas
#
# Supported platforms: Allwinner (MBR), Amlogic (MBR), Rockchip (GPT)
#
# Command: fnnas-tf
#
#========================= Set default parameters ==========================
#
# Load FnNAS configuration file
fnnas_conf="/etc/fnnas.conf"

# Set font color
STEPS="[\033[95m STEPS \033[0m]"
INFO="[\033[94m INFO \033[0m]"
SUCCESS="[\033[92m SUCCESS \033[0m]"
OPTIONS="[\033[93m OPTIONS \033[0m]"
WARNING="[\033[93m WARNING \033[0m]"
ERROR="[\033[91m ERROR \033[0m]"
#
#===========================================================================

# Encountered a serious error, abort the script execution
error_msg() {
    echo -e "${ERROR} ${1}"
    exit 1
}

# Initialize variables
init_var() {
    if [[ -f "${fnnas_conf}" ]]; then
        source "${fnnas_conf}"
    else
        # Set root partition size limit (Unit: GiB)
        echo "rootfs_limit_gib=\"16\"" >"${fnnas_conf}"
        echo "rootfs_resize=\"yes\"" >>"${fnnas_conf}"
        rootfs_limit_gib="16"
        rootfs_resize="yes"
    fi
    # Ensure variables are set
    [[ -n "${rootfs_limit_gib}" ]] || rootfs_limit_gib="16"
    [[ -n "${rootfs_resize}" ]] || rootfs_resize="yes"
}

# Disable the resize-rootfs service
disable_service() {
    if systemctl is-enabled resize-rootfs.service >/dev/null 2>&1; then
        systemctl disable resize-rootfs.service >/dev/null 2>&1
        echo -e "${INFO} Service resize-rootfs.service disabled"
    fi

    # Update configuration to prevent future resizing
    sed -i "s|^rootfs_resize=.*|rootfs_resize=\"no\"|g" "${fnnas_conf}"
}

# Check disk
do_checkdisk() {
    # Find the partition where root is located
    ROOT_PATH="$(findmnt -n -o SOURCE / 2>/dev/null || df -P / | tail -n1 | awk '{print $1}')"
    # Extract only the name (e.g., mmcblk0p2)
    ROOT_PTNAME="$(basename "${ROOT_PATH}")"
    [[ -z "${ROOT_PTNAME}" ]] && error_msg "Cannot find the partition corresponding to the root file system!"

    # Find the disk and partition number
    case "${ROOT_PTNAME}" in
    mmcblk?p[0-9]*)
        # mmcblk0p2 -> DISK: mmcblk0, PART: 2
        DISK_NAME=$(echo "${ROOT_PTNAME}" | sed -E 's/p[0-9]+$//')
        PART_NUM=$(echo "${ROOT_PTNAME}" | grep -oE '[0-9]+$')
        ;;
    [hsv]d[a-z][0-9]*)
        # sda2 -> DISK: sda, PART: 2
        DISK_NAME=$(echo "${ROOT_PTNAME}" | sed -E 's/[0-9]+$//')
        PART_NUM=$(echo "${ROOT_PTNAME}" | grep -oE '[0-9]+$')
        ;;
    nvme?n?p[0-9]*)
        # nvme0n1p2 -> DISK: nvme0n1, PART: 2
        DISK_NAME=$(echo "${ROOT_PTNAME}" | sed -E 's/p[0-9]+$//')
        PART_NUM=$(echo "${ROOT_PTNAME}" | grep -oE '[0-9]+$')
        ;;
    *)
        error_msg "Unrecognized disk type ${ROOT_PTNAME}!"
        ;;
    esac

    # Detect partition table type (gpt or dos/mbr)
    PT_TYPE="$(lsblk -n -o PTTYPE -d "/dev/${DISK_NAME}" 2>/dev/null | tr -d '[:space:]')"
    [[ -z "${PT_TYPE}" ]] && PT_TYPE="unknown"

    echo -e "${INFO} Target Disk: [ ${DISK_NAME} ], Root Partition: [ ${PART_NUM} ], PT Type: [ ${PT_TYPE} ]"
    sync && sleep 3
}

# Expand the current partition
expansion_partition() {
    echo -e "${INFO} Expanding root partition..."

    # --- Step 1: Check if resize is needed ---
    CURRENT_SIZE_BYTES="$(lsblk -b -n -o SIZE "/dev/${ROOT_PTNAME}" 2>/dev/null | head -n1)"
    [[ -z "${CURRENT_SIZE_BYTES}" || "${CURRENT_SIZE_BYTES}" == "0" ]] && error_msg "Failed to get partition size."
    CURRENT_SIZE_GiB=$((CURRENT_SIZE_BYTES / 1024 / 1024 / 1024))

    DISK_SIZE_BYTES="$(lsblk -b -n -o SIZE -d "/dev/${DISK_NAME}" 2>/dev/null)"
    [[ "${DISK_SIZE_BYTES}" =~ ^[0-9]+$ ]] || DISK_SIZE_BYTES="0"
    DISK_SIZE_GiB=$((DISK_SIZE_BYTES / 1024 / 1024 / 1024))

    echo -e "${INFO} Current partition: ${CURRENT_SIZE_GiB}GiB, Disk: ${DISK_SIZE_GiB}GiB"

    # Calculate target end position in bytes for limited strategy
    TARGET_LIMIT_BYTES="$((rootfs_limit_gib * 1024 * 1024 * 1024))"

    if [[ "${DISK_SIZE_BYTES}" -gt "${TARGET_LIMIT_BYTES}" ]]; then
        # === Limited strategy: disk > limit, resize to limit ===
        # CRITICAL: Never shrink a partition — only grow
        if [[ "${CURRENT_SIZE_BYTES}" -ge "${TARGET_LIMIT_BYTES}" ]]; then
            echo -e "${INFO} Partition already >= ${rootfs_limit_gib}GiB target, skip resize."
            disable_service
            return 0
        fi
    else
        # === Full-disk strategy: disk <= limit, expand to 100% ===
        # Skip if less than 1% free space remains (using byte-level comparison)
        if [[ "${DISK_SIZE_BYTES}" -gt "0" ]]; then
            REMAINING_BYTES=$((DISK_SIZE_BYTES - CURRENT_SIZE_BYTES))
            # 1% of disk in bytes: DISK_SIZE_BYTES / 100
            THRESHOLD_BYTES=$((DISK_SIZE_BYTES / 100))
            if [[ "${REMAINING_BYTES}" -lt "${THRESHOLD_BYTES}" ]]; then
                echo -e "${INFO} Partition already at 99%+ of disk, skip resize."
                disable_service
                return 0
            fi
        fi
    fi

    # --- Step 2: Resize partition (platform-aware) ---
    #
    # Partition table types by platform:
    #   Allwinner: msdos (MBR) — bootloader at 8KB (SPL) + 40KB (U-Boot)
    #   Amlogic:   msdos (MBR) — bootloader at sector 0 (444B) + sector 1+
    #   Rockchip:  gpt         — bootloader at 32KB (idbloader) + 8MB (u-boot) + 12MB (trust)
    #
    if [[ "${PT_TYPE}" == "gpt" ]]; then
        # === GPT path (Rockchip) ===
        echo -e "${INFO} GPT partition table detected."

        # Fix GPT backup header location (may be incorrect after writing image to larger disk)
        printf 'f\n' | parted ---pretend-input-tty /dev/${DISK_NAME} unit MiB print >/dev/null 2>&1 || true

        if [[ "${DISK_SIZE_BYTES}" -gt "$((rootfs_limit_gib * 1024 * 1024 * 1024))" ]]; then
            echo -e "${INFO} Strategy: Limit partition ${PART_NUM} to ${rootfs_limit_gib}GiB..."
            printf 'Yes\n' | parted ---pretend-input-tty \
                /dev/${DISK_NAME} resizepart ${PART_NUM} ${rootfs_limit_gib}GiB 2>&1
        else
            echo -e "${INFO} Strategy: Expand partition ${PART_NUM} to 100% (Full Disk)..."
            printf 'Yes\n' | parted ---pretend-input-tty \
                /dev/${DISK_NAME} resizepart ${PART_NUM} 100% 2>&1
        fi
    else
        # === MBR path (Allwinner / Amlogic) ===
        echo -e "${INFO} MBR partition table detected."

        if [[ "${DISK_SIZE_BYTES}" -gt "$((rootfs_limit_gib * 1024 * 1024 * 1024))" ]]; then
            echo -e "${INFO} Strategy: Limit partition ${PART_NUM} to ${rootfs_limit_gib}GiB..."
            printf 'Yes\n' | parted ---pretend-input-tty \
                /dev/${DISK_NAME} resizepart ${PART_NUM} ${rootfs_limit_gib}GiB
        else
            echo -e "${INFO} Strategy: Expand partition ${PART_NUM} to 100% (Full Disk)..."
            printf 'Yes\n' | parted ---pretend-input-tty \
                /dev/${DISK_NAME} resizepart ${PART_NUM} 100%
        fi
    fi

    # --- Step 3: Update kernel partition cache ---
    partx --update /dev/${DISK_NAME} 2>/dev/null || true
    sync && sleep 3

    # --- Step 4: Resize filesystem ---
    echo -e "${INFO} Expanding filesystem..."
    ROOTFS_TYPE="$(df -T / | tail -n1 | awk '{print $2}')"

    if [[ "${ROOTFS_TYPE}" == "btrfs" ]]; then
        btrfs filesystem resize max /
        if [[ "${?}" -ne "0" ]]; then
            echo -e "${ERROR} [ btrfs ] operation failed, disabling service to prevent retry loop."
            disable_service
            exit 1
        fi
    else
        resize2fs /dev/${ROOT_PTNAME}
        if [[ "${?}" -ne "0" ]]; then
            echo -e "${ERROR} [ resize2fs ] operation failed, disabling service to prevent retry loop."
            disable_service
            exit 1
        fi
    fi

    echo -e "${SUCCESS} Partition expanded successfully."
}

# Show welcome message
echo -e "${STEPS} Welcome to the partition expansion tool."
# Check for root privileges
[[ "$(id -u)" -ne "0" ]] && error_msg "This script must be run as root!"
# Initialize variables
init_var
# Check if root filesystem auto-resize is disabled
[[ "${rootfs_resize}" == "yes" ]] || {
    echo -e "${INFO} Root filesystem auto-resize is disabled. Exiting."
    exit 0
}
# Check disk and partition info
do_checkdisk
# Expand partition
expansion_partition
# Disable service
disable_service
